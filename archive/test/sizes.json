{
  "description": "Beverage sizes as scalePercent of base (medium = 100%). Inventory and recipes store base qty at 100%; multiply at order time.",
  "defaultSizeId": "size-medium",
  "sizes": [
    {
      "id": "size-small",
      "name": "Small",
      "abbrev": "S",
      "scalePercent": 75,
      "priceMultiplier": 0.85
    },
    {
      "id": "size-medium",
      "name": "Medium",
      "abbrev": "M",
      "scalePercent": 100,
      "priceMultiplier": 1.0,
      "isDefault": true
    },
    {
      "id": "size-large",
      "name": "Large",
      "abbrev": "L",
      "scalePercent": 125,
      "priceMultiplier": 1.25
    }
  ],
  "appliesToCategories": ["coffee", "tea", "juice"],
  "formula": {
    "usageQty": "baseQty * (scalePercent / 100)",
    "sellPrice": "baseSellPrice * priceMultiplier"
  }
}
