# Single Railway service: Next.js web + FastAPI agent (free-tier friendly).
FROM node:20-bookworm-slim AS web-deps
WORKDIR /app
COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/
RUN npm ci

FROM node:20-bookworm-slim AS web-builder
WORKDIR /app
COPY --from=web-deps /app/node_modules ./node_modules
COPY package.json package-lock.json ./
COPY apps/web ./apps/web
COPY backend/api ./backend/api
ENV NEXT_TELEMETRY_DISABLED=1
ENV PATH="/app/node_modules/.bin:${PATH}"
WORKDIR /app/apps/web
RUN npm run build

FROM python:3.12-slim AS runner
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl \
  && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
  && apt-get install -y --no-install-recommends nodejs \
  && rm -rf /var/lib/apt/lists/*

COPY backend/agent-service/requirements.txt ./agent/requirements.txt
RUN pip install --no-cache-dir -r agent/requirements.txt

COPY backend/agent-service ./agent
COPY --from=web-builder /app/node_modules ./node_modules
COPY --from=web-builder /app/package.json ./package.json
COPY --from=web-builder /app/apps/web ./apps/web
COPY --from=web-builder /app/backend/api ./backend/api

COPY infra/scripts/railway-start.sh ./railway-start.sh
RUN chmod +x ./railway-start.sh

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV AGENT_SERVICE_URL=http://127.0.0.1:8000
ENV USE_LANGCHAIN_AGENTS=true

EXPOSE 3000
CMD ["./railway-start.sh"]
