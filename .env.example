# Copy to .env and fill in values: cp .env.example .env

# MongoDB (Docker default matches docker-compose.yml)
MONGODB_URI=mongodb://localhost:27017/sous_chef

# NextAuth — generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# OpenAI (required for chat + bill parsing later)
OPENAI_API_KEY=sk-your-key-here

# Google OAuth (optional bonus for M32)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Agent service (FastAPI)
AGENT_SERVICE_URL=http://localhost:8000

# Local object storage mirror (Cloudflare R2 layout). Selected images saved on catalog add.
# R2_STORAGE_ROOT=/absolute/path/to/storage/r2

# Optional: max supplier/customer bills parsed in parallel by the agent (1–5, default 5)
# BILL_PIPELINE_PARALLEL=5

# App
NODE_ENV=development
